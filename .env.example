# =============================================================================
# Variables de entorno - Entorno de desarrollo local (docker-compose.dev.yml)
# Copiar este archivo a ".env" y ajustar valores si es necesario.
# NUNCA commitear el archivo ".env" real (ya esta en .gitignore).
# =============================================================================

# === PostgreSQL ===
POSTGRES_DB=inventario
POSTGRES_USER=inventario_user
POSTGRES_PASSWORD=inventario_pass
POSTGRES_PORT=5432

# === Keycloak ===
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=inventario
# Issuer URI publico (usado para validar el claim "iss" del JWT, debe matchear KC_HOSTNAME)
KEYCLOAK_ISSUER_URI=http://localhost:8080/realms/inventario
# JWKS URI interno (red docker) usado por el backend para obtener las llaves de firma
KEYCLOAK_JWK_SET_URI=http://keycloak:8080/realms/inventario/protocol/openid-connect/certs
# Secret del client confidencial "inventario-backend" (definido en keycloak/realm.json, solo dev)
KEYCLOAK_CLIENT_SECRET=inventario-backend-secret

# === Backend (Spring Boot) ===
BACKEND_PORT=8081
SPRING_PROFILES_ACTIVE=dev
# Origenes permitidos por CORS (lista separada por comas), debe incluir la URL del frontend
CORS_ALLOWED_ORIGINS=http://localhost:5173

# === Prometheus ===
PROMETHEUS_PORT=9090

# === Grafana ===
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
