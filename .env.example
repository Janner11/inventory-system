# =============================================================================
# Variables de entorno - Entorno de desarrollo local (docker-compose.dev.yml)
# Copiar este archivo a ".env" y ajustar valores si es necesario.
# NUNCA commitear el archivo ".env" real (ya esta en .gitignore).
# =============================================================================

# === PostgreSQL ===
POSTGRES_DB=inventario
POSTGRES_USER=inventario_user
POSTGRES_PASSWORD=inventario_pass
POSTGRES_PORT=5432

# === Keycloak ===
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=inventario
KEYCLOAK_ISSUER_URI=http://keycloak:8080/realms/inventario

# === Backend (Spring Boot) ===
BACKEND_PORT=8081
SPRING_PROFILES_ACTIVE=dev

# === Prometheus ===
PROMETHEUS_PORT=9090

# === Grafana ===
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
